# Server-only values (Vercel project settings; never prefix with VITE_)
FIREBASE_PROJECT_ID=ahad-cleaning
FIRESTORE_DATABASE_ID=(default)
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@example.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-me\n-----END PRIVATE KEY-----\n"
# Alternative to the three values above: one complete service-account JSON value.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

RESEND_API_KEY=re_replace_me
RESEND_FROM=AHAD Cleaning <noreply@ahad-cleaning.de>
LEAD_TO=info@ahad-cleaning.de
LEAD_ALLOWED_ORIGINS=https://www.ahad-cleaning.de,https://ahad-cleaning.de
LEAD_RATE_LIMIT_SECRET=replace-with-at-least-32-random-characters
LEAD_RATE_MAX=5
LEAD_RATE_WINDOW_MS=60000
PRIVACY_NOTICE_VERSION=2026-07-12
WHATSAPP_NOTICE_VERSION=2026-07-12

# Optional public Firebase client overrides used by /admin only.
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
