{
  "name": "ahad-cleaning-website",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:client": "npm run typecheck:app && vite build",
    "build:ssr": "vite build --config vite.ssr.config.ts",
    "prerender": "node scripts/prerender.mjs",
    "build": "npm run build:client && npm run build:ssr && npm run prerender",
    "postbuild": "npm run check:dist",
    "preview": "vite preview",
    "build:file": "VITE_HASH_ROUTER=1 vite build --config vite.singlefile.config.ts",
    "assets": "node scripts/generate-assets.mjs",
    "lint": "eslint .",
    "typecheck": "tsc -b",
    "typecheck:app": "tsc -p tsconfig.app.json",
    "typecheck:api": "tsc -p tsconfig.api.json",
    "typecheck:vite": "tsc -p tsconfig.node.json",
    "test": "npm run test:unit",
    "test:unit": "node --experimental-strip-types --test \"tests/*.test.ts\"",
    "test:e2e": "playwright test",
    "check:dist": "node scripts/check-performance-budget.mjs",
    "firebase:deploy": "npx --yes firebase-tools@15.23.0 deploy --only firestore:rules,firestore:indexes"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "clsx": "^2.1.1",
    "firebase": "^11.1.0",
    "firebase-admin": "^14.1.0",
    "lucide-react": "^0.469.0",
    "motion": "^12.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-router-dom": "^7.1.1",
    "resend": "^6.14.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "sharp": "^0.33.5",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^6.0.7",
    "vite-plugin-singlefile": "^2.3.3"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
