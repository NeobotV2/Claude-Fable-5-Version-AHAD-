{
  "name": "ahad-cleaning-website",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:client": "tsc -b && vite build",
    "build:ssr": "vite build --config vite.ssr.config.ts",
    "prerender": "node scripts/prerender.mjs",
    "build": "npm run build:client && npm run build:ssr && npm run prerender",
    "preview": "vite preview",
    "build:file": "VITE_HASH_ROUTER=1 vite build --config vite.singlefile.config.ts",
    "assets": "node scripts/generate-assets.mjs"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "firebase": "^11.1.0",
    "lucide-react": "^0.469.0",
    "motion": "^12.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-router-dom": "^7.1.1",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "sharp": "^0.33.5",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.7.2",
    "vite": "^6.0.7",
    "vite-plugin-singlefile": "^2.3.3"
  }
}
